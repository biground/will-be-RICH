# ------------------------------------------------------------------
# 工具函数
# ------------------------------------------------------------------
def get_template_by_id(template_id: str) -> dict | None:
    """根据 ID 获取策略模板"""
    for t in STRATEGY_TEMPLATES:
        if t["id"] == template_id:
            return t
    return None


def get_all_templates() -> list[dict]:
    """获取所有策略模板"""
    return STRATEGY_TEMPLATES


def get_risk_badge_html(risk_level: str, risk_color: str) -> str:
    """返回风险等级徽章的 HTML"""
    return (
        f'<span style="display:inline-block;background:{risk_color};'
        f'color:#fff;font-size:0.72rem;font-weight:600;'
        f'padding:0.15rem 0.55rem;border-radius:99px;">'
        f'{risk_level}</span>'
    )
